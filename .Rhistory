y = "Total abundance"
)
ggplot(bruv_data, aes(x = mean_relief, y = richness)) +
geom_point(alpha = 0.6) +
geom_smooth(method = "glm", method.args = list(family = "poisson"), color = "darkgreen") +
theme_classic() +
labs(
